# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sift

# Ollama (defaults: http://localhost:11434, llama3.2)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Optional
LOG_LEVEL=INFO

CODEQL_ENABLED=0
CODEQL_SUITE=default
CODEQL_TIMEOUT=600
SIFT_CLONE_CACHE_DIR=~/.sift/clones

# Vector DB / code similarity (default: disabled)
VECTOR_DB_ENABLED=0
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
VECTOR_SIMILARITY_TOP_K=5
VECTOR_EXCLUDE_SAME_FILE=1
