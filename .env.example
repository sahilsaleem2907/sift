
# Database
DATABASE_URL=postgresql://user:password@localhost:5432/sift

# LLM provider (LiteLLM). Set LLM_MODEL to any LiteLLM-compatible model; default is Ollama (local, no API key).
LLM_MODEL=ollama/llama3.2
LLM_API_BASE=http://localhost:11434

# OpenAI
# LLM_MODEL=openai/gpt-4o
# OPENAI_API_KEY=sk-...

# Anthropic
# LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# LLM_MODEL=gemini/gemini-2.0-flash
# GEMINI_API_KEY=...

# Azure OpenAI
# LLM_MODEL=azure/<your-deployment-name>
# LLM_API_BASE=https://your-resource.openai.azure.com
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-08-01-preview

# AWS Bedrock (uses IAM credentials)
# LLM_MODEL=bedrock/anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION_NAME=us-east-1

# Optional: bearer token to protect POST /review (GitHub Actions flow) and authenticate to the token service; omit to allow unauthenticated /review
# SIFT_API_KEY=

# Optional
LOG_LEVEL=INFO

SEMGREP_ENABLED=1
CODEQL_ENABLED=0
CODEQL_SUITE=default
CODEQL_TIMEOUT=600
SIFT_CLONE_CACHE_DIR=~/.sift/clones

# JS/TS ecosystem tools (default: all enabled)
OXLINT_ENABLED=1
NPM_AUDIT_ENABLED=1
YARN_AUDIT_ENABLED=1
SEMGREP_FRAMEWORK_RULES_ENABLED=1

# Vector DB / code similarity (default: disabled)
VECTOR_DB_ENABLED=0
EMBEDDING_MODEL=ollama/nomic-embed-text
EMBEDDING_API_BASE=http://localhost:11434
EMBEDDING_DIMENSION=768
VECTOR_SIMILARITY_TOP_K=5
VECTOR_EXCLUDE_SAME_FILE=1

# OpenAI embeddings alternative (dimension=1536)
# EMBEDDING_MODEL=openai/text-embedding-3-small
# EMBEDDING_DIMENSION=1536

# Concurrency / rate limiting (defaults: 10 concurrent reviews, 0.5s after each LLM call, 0.2s between GitHub comments)
SIFT_MAX_CONCURRENT_REVIEWS=10
SIFT_LLM_REQUEST_DELAY=0.5
SIFT_GITHUB_COMMENT_DELAY=0.2

# PR blocking via GitHub commit status (default: disabled)
# When enabled, Sift posts a commit status (pending → success/failure) after each review.
# Pair with a GitHub branch protection rule requiring the "sift/review" status check.
SIFT_BLOCK_PRS_ENABLED=0
SIFT_BLOCK_ON_SEVERITIES=bug,security   # comma-separated: bug,security,warning,suggestion
SIFT_BLOCK_MIN_FINDINGS=1               # block when this many qualifying findings are found
SIFT_STATUS_CONTEXT=sift/review         # name shown in branch protection UI

# Review engine effort and secondary model
# SIFT_REVIEW_EFFORT=balanced          # low | balanced | high (default: balanced)
# SIFT_REVIEW_MODEL=anthropic/claude-haiku-4-5   # separate model for critic/holistic passes
# SIFT_REVIEW_MODEL_KEY=sk-ant-...
# SIFT_REVIEW_MODEL_BASE_URL=
# SIFT_CAPABILITY_OVERRIDE=           # JSON: {"context_window":32768,"supports_function_calling":true,"supports_reasoning":false}
# SIFT_AGENTIC_MAX_STEPS=4
